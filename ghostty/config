# Font
font-family = JetBrainsMono Nerd Font
font-size = 14

# Shell
command = /bin/zsh

# Window
window-padding-x = 8
window-padding-y = 8

# Theme
theme = Catppuccin Mocha

# Cursor
cursor-style = block
cursor-style-blink = false

# Shell integration
shell-integration = zsh
shell-integration-features = cursor,sudo,title
